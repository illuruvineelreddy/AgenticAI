{
  "dashboard": {
    "id": null,
    "uid": "astra-trading",
    "title": "Project Astra - Trading Dashboard",
    "tags": ["trading", "astra"],
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 0,
    "refresh": "5s",
    "panels": [
      {
        "id": 1,
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "type": "graph",
        "title": "Market Ticks Rate",
        "targets": [
          {
            "expr": "rate(market_ticks_total[1m])",
            "legendFormat": "{{symbol}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 2,
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "type": "singlestat",
        "title": "Total Trades Approved",
        "targets": [
          {
            "expr": "sum(trades_approved_total)",
            "refId": "A"
          }
        ],
        "format": "none"
      },
      {
        "id": 3,
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "type": "graph",
        "title": "Strategy Signals",
        "targets": [
          {
            "expr": "rate(strategy_signals_total[5m])",
            "legendFormat": "{{strategy}} - {{direction}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 4,
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "type": "table",
        "title": "Risk Checks",
        "targets": [
          {
            "expr": "risk_checks_total",
            "legendFormat": "{{result}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 5,
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "type": "singlestat",
        "title": "Open Positions",
        "targets": [
          {
            "expr": "count(open_positions)",
            "refId": "A"
          }
        ],
        "format": "none"
      },
      {
        "id": 6,
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
        "type": "singlestat",
        "title": "Total Realized PnL",
        "targets": [
          {
            "expr": "total_realized_pnl",
            "refId": "A"
          }
        ],
        "format": "currencyINR"
      },
      {
        "id": 7,
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
        "type": "graph",
        "title": "Execution Latency",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(execution_latency_seconds_bucket[5m]))",
            "legendFormat": "95th percentile",
            "refId": "A"
          }
        ]
      },
      {
        "id": 8,
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
        "type": "graph",
        "title": "System Uptime",
        "targets": [
          {
            "expr": "system_uptime",
            "legendFormat": "Uptime (seconds)",
            "refId": "A"
          }
        ]
      }
    ]
  }
}
