# Environment Variables for Project Astra - Local Development

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DB_USER=astra
DB_PASSWORD=astra_secure_123
DB_NAME=astra_trading
DB_PORT=5432
DB_HOST=localhost

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# =============================================================================
# BROKER API CREDENTIALS (Zerodha Kite Example)
# Leave empty for paper trading mode
# =============================================================================
BROKER_API_KEY=your_broker_api_key_here
BROKER_API_SECRET=your_broker_api_secret_here
BROKER_NAME=zerodha  # Options: zerodha, upstox, fyers, dhan

# =============================================================================
# TELEGRAM ALERTS
# =============================================================================
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
TELEGRAM_ENABLED=false

# =============================================================================
# BACKEND CONFIGURATION
# =============================================================================
BACKEND_PORT=8000
ENVIRONMENT=development
LOG_LEVEL=DEBUG
PAPER_TRADING_MODE=true

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# =============================================================================
# GRAFANA CONFIGURATION
# =============================================================================
GRAFANA_PORT=3001
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin123

# =============================================================================
# PROMETHEUS CONFIGURATION
# =============================================================================
PROMETHEUS_PORT=9090

# =============================================================================
# TRADING CONFIGURATION
# =============================================================================
MAX_RISK_PER_TRADE=0.01  # 1% of capital
MAX_DAILY_DRAWDOWN=0.03  # 3% daily loss limit
MAX_OPEN_POSITIONS=5
DEFAULT_CAPITAL=1000000  # 10 Lakhs for paper trading

# =============================================================================
# REPLAY ENGINE CONFIGURATION
# =============================================================================
REPLAY_SPEED=1x  # Options: 1x, 5x, 10x, 50x
REPLAY_START_DATE=2024-01-01
REPLAY_END_DATE=2024-12-31

# =============================================================================
# ML MODEL CONFIGURATION
# =============================================================================
MODEL_PATH=/models
DATASET_PATH=/datasets
ENABLE_SHAP=true
ML_INFERENCE_BATCH_SIZE=100
